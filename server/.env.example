# ==============================================
# Voleena Foods - Environment Variables
# ==============================================

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=voleena_foods_db
DB_PORT=3306

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRE=30m
JWT_REFRESH_EXPIRE=7d

# Google Maps API (FR09 - Distance Validation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
RESTAURANT_LATITUDE=7.0000000
RESTAURANT_LONGITUDE=80.0000000

# Email Configuration (SMTP) - FR15, FR27, FR28, FR31
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@voleenafoods.lk

# SMS Configuration (Optional - FR15, FR27, FR28)
SMS_PROVIDER=console
# For Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway - PayHere (FR30, FR31)
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret
PAYHERE_MODE=sandbox

# Payment Gateway - Stripe (FR30, FR31)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_WEBHOOK_URL=http://localhost:3001/api/v1/payments/webhook/stripe

# System Settings
MAX_DELIVERY_DISTANCE_KM=15
SESSION_TIMEOUT_MINUTES=30
ORDER_AUTO_CANCEL_MINUTES=30
MIN_ORDER_AMOUNT=500

# Dynamic Delivery Fee Configuration (Distance-Based Pricing)
# Base delivery fee applies to all delivery orders
BASE_DELIVERY_FEE=100
# Distance within which only base fee applies (no distance surcharge)
FREE_DELIVERY_DISTANCE_KM=3
# Additional cost per kilometer beyond free delivery range
DELIVERY_FEE_PER_KM=20
# Maximum delivery fee cap to keep pricing reasonable
MAX_DELIVERY_FEE=300

# Tax Configuration (Set to 0 as per business decision)
TAX_PERCENTAGE=0

# File Upload
UPLOAD_DIR=./Assets
MAX_FILE_SIZE=5242880

# Logging
LOG_LEVEL=info
