PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=voleena_foods_db
DB_PORT=3306

# JWT Security (CHANGE IN PRODUCTION)
JWT_SECRET=development_jwt_secret_minimum_32_characters_long_change_in_prod
JWT_EXPIRE=30m
JWT_REFRESH_SECRET=development_refresh_secret_minimum_32_characters_long_change
JWT_REFRESH_EXPIRE=7d

# Google Maps API (Optional for development)
GOOGLE_MAPS_API_KEY=
RESTAURANT_LATITUDE=7.0000000
RESTAURANT_LONGITUDE=80.0000000

# Email Configuration (Optional for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@voleenafoods.lk

# SMS Configuration (Optional for development)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Gateway - PayHere (Optional for development)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox
PAYHERE_NOTIFY_URL=http://localhost:3001/api/v1/payments/payhere/notify
PAYHERE_RETURN_URL=http://localhost:5173/order-confirmation
PAYHERE_CANCEL_URL=http://localhost:5173/checkout

# Payment Gateway - Stripe (Optional for development)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# System Settings
MAX_DELIVERY_DISTANCE_KM=15
SESSION_TIMEOUT_MINUTES=30
ORDER_AUTO_CANCEL_MINUTES=30
MIN_ORDER_AMOUNT=500
DELIVERY_FEE=150
TAX_PERCENTAGE=0

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=3

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
