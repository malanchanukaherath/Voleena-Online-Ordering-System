# Docker Compose project naming
COMPOSE_PROJECT_NAME=voleena

# Published ports on host
FRONTEND_PUBLIC_PORT=8080
BACKEND_PUBLIC_PORT=3001
DB_PUBLIC_PORT=3306

# Backend container runtime
NODE_ENV=production
BACKEND_CONTAINER_PORT=3001
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=voleena_foods_db
DB_USER=voleena_user
DB_PASSWORD=voleena_password
DB_ROOT_PASSWORD=root_password
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=2000

# Auth
JWT_SECRET=change_this_to_a_minimum_32_character_secret!@#
JWT_REFRESH_SECRET=change_this_to_a_different_32_character_secret!@#
JWT_EXPIRE=30m
JWT_REFRESH_EXPIRE=7d

# Mapping and delivery
GOOGLE_MAPS_API_KEY=replace_me
RESTAURANT_LATITUDE=7.0000000
RESTAURANT_LONGITUDE=80.0000000
MAX_DELIVERY_DISTANCE_KM=15

# Stripe and PayHere
STRIPE_SECRET_KEY=replace_me
STRIPE_PUBLISHABLE_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
PAYHERE_MERCHANT_ID=replace_me
PAYHERE_MERCHANT_SECRET=replace_me
PAYHERE_MODE=sandbox

# Email and SMS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM=replace_me
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace_me
EMAIL_FROM=onboarding@resend.dev
EMAIL_VERIFICATION_TTL_MINUTES=30
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=replace_me

# Delivery fee and throttling
BASE_DELIVERY_FEE=100
FREE_DELIVERY_DISTANCE_KM=3
DELIVERY_FEE_PER_KM=20
MAX_DELIVERY_FEE=300
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend build-time variables
VITE_API_BASE_URL=http://localhost:3001
VITE_GOOGLE_MAPS_API_KEY=replace_me
VITE_STRIPE_PUBLISHABLE_KEY=replace_me
