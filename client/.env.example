# Frontend Environment Variables
# In Docker builds, values are provided from root .env via docker-compose.yml
# For local Vite dev, copy this file to .env.local and fill in your values

# Vite React PORT (used only for local Vite dev)
VITE_FRONTEND_PORT=5173

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:3001

# Google Maps API Key (Required for delivery tracking map)
# Get your API key from: https://console.cloud.google.com/
# Make sure to enable: Maps JavaScript API, Distance Matrix API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe Payment Gateway (Required for card payments)
# Get your Publishable Key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Node Environment
VITE_NODE_ENV=development