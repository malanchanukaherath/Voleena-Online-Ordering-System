# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Vite React PORT (default: 5173)
VITE_FRONTEND_PORT=5173

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:3001

# Google Maps API Key (Required for delivery tracking map)
# Get your API key from: https://console.cloud.google.com/
# Make sure to enable: Maps JavaScript API, Distance Matrix API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=AIzaSyBV4YZqTuL2BuahZQf-Tezt9CNG2cwjBvs

# Node Environment
VITE_NODE_ENV=development
